{
  "nodes": {
    "0": {
      "scenes": [
        {
          "id": "0-start",
          "bg": "room",
          "npc": "치키_기본치키",
          "speaker": "치키",
          "speaker_role": "루프 관리자",
          "location": "주인공의 방",
          "place": "집",
          "text": "자, 시간이 없어!\n 널 노리는 범인을 찾아야 해.\n 출근할래, 아니면 집에 숨어있을래?"
        }
      ],
      "choices": [
        {
          "id": 100,
          "text": "집에 있는다"
        },
        {
          "id": 101,
          "text": "출근한다"
        }
      ]
    },
    "100": {
      "scenes": [
        {
          "id": "100-S1",
          "bg": "kitchen",
          "npc": "엄마_밥",
          "speaker": null,
          "speaker_role": null,
          "location": "부엌",
          "place": "집",
          "text": "엄마와 부엌에서 밥 먹는 중이다.."
        },
        {
          "id": "100-S2",
          "bg": "kitchen",
          "npc": "엄마_밥먹어라",
          "speaker": "엄마",
          "speaker_role": "주인공의 어머니",
          "location": "부엌",
          "place": "집",
          "text": "요즘은 좀 어떠니. 지난번엔 환자 일 때문에 힘들다더니…\n그 뒤로는 별일 없었어?"
        },
        {
          "id": "100-S2-2",
          "bg": "kitchen",
          "npc": "엄마_실망",
          "speaker": "엄마",
          "speaker_role": "주인공의 어머니",
          "location": "부엌",
          "place": "집",
          "text": "..."
        },
        {
          "id": "100-S3",
          "bg": "kitchen",
          "npc": "엄마_낙담",
          "speaker": "엄마",
          "speaker_role": "주인공의 어머니",
          "location": "부엌",
          "place": "집",
          "text": "넌 정말, 예전이나 지금이나 말이 없구나.\n...내일이 나영이 기일인 건 알고 있는 거니?"
        }
      ],
      "choices": [
        {
          "id": 200,
          "text": "알고 있다고 말한다"
        },
        {
          "id": 201,
          "text": "모른다고 말한다"
        }
      ]
    },
    "200": {
      "scenes": [
        {
          "id": "200-S4a",
          "bg": "kitchen",
          "npc": "엄마_밥먹어라",
          "speaker": "엄마",
          "speaker_role": "주인공의 어머니",
          "location": "부엌",
          "place": "집",
          "text": "그래… 그래도 동생 기일은 잊지 않았구나.\n우리 애가 아주 모질진 않아서 다행이네.\n엄마가 또 괜히 날을 세웠지… 미안하다."
        },
        {
          "id": "200-S5",
          "bg": "kitchen",
          "npc": "박도원_문막열었을때",
          "speaker": "박도원",
          "speaker_role": "건물 청소부 / 택배 기사",
          "location": "부엌",
          "place": "집",
          "text": "계십니까~ 택배 왔습니다.",
          "sound": "초인종"
        }
      ],
      "choices": [
        {
          "id": 300,
          "text": "택배를 받으러 나간다"
        },
        {
          "id": 301,
          "text": "나가지 않는다"
        }
      ]
    },
    "201": {
      "scenes": [
        {
          "id": "201-S4b",
          "bg": "kitchen",
          "npc": "엄마_화",
          "speaker": "엄마",
          "speaker_role": "주인공의 어머니",
          "location": "부엌",
          "place": "집",
          "text": "...모른다고?\n자기 동생 기일도 잊어버리고 사니?"
        },
        {
          "id": "201-S4b-1",
          "bg": "kitchen",
          "npc": "엄마_화",
          "speaker": "엄마",
          "speaker_role": "주인공의 어머니",
          "location": "부엌",
          "place": "집",
          "text": "세상 사람들한텐 다정한 척하면서, 정작 가족한텐 어쩜 이렇게 무심하니.\n나영이가 살아 있었어도, 네가 이렇게까지 잊길 바랐을까?"
        },
        {
          "id": "201-S4b-2",
          "bg": "kitchen",
          "npc": "엄마_화",
          "speaker": "엄마",
          "speaker_role": "주인공의 어머니",
          "location": "부엌",
          "place": "집",
          "text": "엄마는 가끔 네가 정말 아무렇지도 않은 사람처럼 보여서… 그게 더 무섭다."
        },
        {
          "id": "201-S5",
          "bg": "kitchen",
          "npc": "박도원_문막열었을때",
          "speaker": "박도원",
          "speaker_role": "건물 청소부 / 택배 기사",
          "location": "부엌",
          "place": "집",
          "text": "택배 왔습니다~ 계신가요?",
          "sound": "초인종"
        }
      ],
      "choices": [
        {
          "id": 300,
          "text": "택배를 받으러 나간다"
        },
        {
          "id": 301,
          "text": "나가지 않는다"
        }
      ]
    },
    "300": {
      "scenes": [
        {
          "id": "300-S6a-1",
          "bg": "entrance",
          "npc": "박도원_은은한미소_착한사람인척",
          "speaker": "박도원",
          "speaker_role": "건물 청소부 / 택배 기사",
          "location": "현관 앞",
          "place": "집",
          "text": "아이고, 선생님. 안녕하십니까. 오랜만에 뵙네요.\n아… 못 알아보시겠군요."
        },
        {
          "id": "300-S6a-2",
          "bg": "entrance",
          "npc": "박도원_악수",
          "speaker": "박도원",
          "speaker_role": "건물 청소부 / 택배 기사",
          "location": "현관 앞",
          "place": "집",
          "text": "저는 선생님 계신 <안식>에서 청소 일 하는 박도원이라고 합니다."
        },
        {
          "id": "300-S6a-3",
          "bg": "entrance",
          "npc": "박도원_악수",
          "speaker": "박도원",
          "speaker_role": "건물 청소부 / 택배 기사",
          "location": "현관 앞",
          "place": "집",
          "text": "허허… 먹고살자니 이것저것 다 하게 되네요.\n낮에는 청소하고, 이렇게 택배 일도 좀 하고 있습니다."
        },
        {
          "id": "300-S6a-4",
          "bg": "entrance",
          "npc": "박도원_하이",
          "speaker": "박도원",
          "speaker_role": "건물 청소부 / 택배 기사",
          "location": "현관 앞",
          "place": "집",
          "text": "아, 그런데 말입니다.\n제가 어제 청소를 하다가… 뭘 하나 주웠는데요."
        },
        {
          "id": "300-S7a",
          "bg": "entrance",
          "npc": "박도원_Usb4",
          "speaker": "박도원",
          "speaker_role": "건물 청소부 / 택배 기사",
          "location": "현관 앞",
          "place": "집",
          "text": "이런 USB 하나가 떨어져 있더라고요. 제 물건은 아닌 것 같고…\n왠지 선생님께 드려야 할 것 같아서요.\n병원에서 잃어버리신 건 아닌지 한번 보시겠습니까?"
        }
      ],
      "choices": [
        {
          "id": 400,
          "text": "USB를 받는다"
        },
        {
          "id": 401,
          "text": "USB를 받지 않는다"
        }
      ]
    },
    "301": {
      "scenes": [
        {
          "id": "301-S6b-1",
          "bg": "kitchen",
          "npc": "엄마_불안",
